# kaja.tools edge gateway.
#
# Fly terminates TLS at the edge and forwards decrypted HTTP/2 (h2c) to this
# Caddy on :80 (see http_options.h2_backend in fly.toml). Caddy path-routes to
# the private backend apps over Fly's private network (<app>.internal:<port>),
# replacing the old nginx-ingress. gRPC backends are reached over h2c.
{
	admin off
	# Fly owns TLS; Caddy only serves plaintext h1/h2c on :80.
	auto_https off
	servers {
		protocols h1 h2c
	}
}

:80 {
	# --- gRPC (HTTP/2 cleartext to the backend) ---

	# seating gRPC service
	@seating path /seating.Seating/*
	handle @seating {
		reverse_proxy h2c://kaja-seating.internal:50053
	}

	# quirks gRPC services (v1 + v2)
	@quirks_grpc path /quirks.v1.Basics/* /quirks.v1.Quirks/* /quirks.v1.quirks_2/* /quirks.v2.Quirks/*
	handle @quirks_grpc {
		reverse_proxy h2c://kaja-quirks-grpc.internal:50053
	}

	# gRPC server reflection routes to a single backend (seating).
	# For grpcurl against other services, use -import-path with the proto files.
	@reflection path /grpc.reflection.v1.ServerReflection/* /grpc.reflection.v1alpha.ServerReflection/*
	handle @reflection {
		reverse_proxy h2c://kaja-seating.internal:50053
	}

	# --- HTTP/1.1 services ---

	# box office Twirp service (serves under /boxoffice/twirp)
	handle /boxoffice/* {
		reverse_proxy kaja-boxoffice.internal:41531
	}

	# quirks Twirp service (serves under /twirp-quirks/twirp)
	handle /twirp-quirks/* {
		reverse_proxy kaja-quirks-twirp.internal:41523
	}

	# theatre OpenAPI service (serves under /theatre)
	handle /theatre/* {
		reverse_proxy kaja-theatre.internal:41530
	}

	# kaja demo IDE (serves under /demo)
	@demo path /demo /demo/*
	handle @demo {
		reverse_proxy kaja-demo.internal:41520
	}

	# Everything else -> home static site
	handle {
		reverse_proxy kaja-home.internal:8080
	}
}
